# ==============================================
# CineList Environment Variables
# Copy this file to .env.local and fill in values
# ==============================================

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Optional: Clerk webhook secret (for user sync webhook)
# CLERK_WEBHOOK_SECRET=whsec_...

# TMDB API (https://www.themoviedb.org/settings/api)
# Use the "API Read Access Token" (Bearer token), NOT the API key
TMDB_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiJ9...

# Google Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AI...
