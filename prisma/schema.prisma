generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  username  String?  @unique
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lists         MovieList[]
  likes         ListLike[]
  ratings       MovieRating[]
  watchlist     WatchlistItem[]
  watchHistory  WatchHistoryItem[]
  comments      ListComment[]
}

model MovieList {
  id            String   @id @default(cuid())
  name          String
  description   String?
  aiDescription String?
  slug          String   @unique
  isPublic      Boolean  @default(false)
  userId        String
  forkedFromId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  forkedFrom MovieList?    @relation("Forks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks      MovieList[]   @relation("Forks")
  items      ListItem[]
  likes      ListLike[]
  tags       ListTag[]
  comments   ListComment[]

  @@index([userId])
  @@index([isPublic, updatedAt])
}

model ListItem {
  id         String   @id @default(cuid())
  tmdbId     Int
  title      String
  posterPath String?
  year       String?
  notes      String?
  order      Int
  listId     String
  createdAt  DateTime @default(now())

  list MovieList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, tmdbId])
  @@index([listId, order])
}

model ListLike {
  id        String   @id @default(cuid())
  userId    String
  listId    String
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  list MovieList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([userId, listId])
}

model ListTag {
  id     String @id @default(cuid())
  name   String
  listId String

  list MovieList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, name])
  @@index([name])
}

model ListComment {
  id        String   @id @default(cuid())
  body      String
  userId    String
  listId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  list     MovieList     @relation(fields: [listId], references: [id], onDelete: Cascade)
  parent   ListComment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ListComment[] @relation("Replies")

  @@index([listId, createdAt])
}

model MovieRating {
  id        String   @id @default(cuid())
  tmdbId    Int
  rating    Int // 1-10
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
  @@index([tmdbId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  tmdbId    Int
  title     String
  posterPath String?
  year      String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
}

model WatchHistoryItem {
  id         String   @id @default(cuid())
  tmdbId     Int
  title      String
  posterPath String?
  year       String?
  runtime    Int?
  genreIds   String? // comma-separated genre IDs
  userId     String
  watchedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
  @@index([userId, watchedAt])
}
